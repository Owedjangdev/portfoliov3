# --- Serveur ---
PORT=5000
NODE_ENV=development

# Origine autorisée pour le CORS (URL du frontend Vite)
CLIENT_ORIGIN=http://localhost:5173

# --- Base de données MongoDB ---
# Atlas: mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/portfolio
# Local: mongodb://127.0.0.1:27017/portfolio
MONGODB_URI=

# --- Authentification (JWT) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Compte admin (utilisé par `npm run seed:admin`) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Owedev

# --- Emails (Nodemailer / SMTP) ---
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
#        SMTP_USER=ton@gmail.com, SMTP_PASS=<mot_de_passe_application_16_caracteres>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Adresse qui reçoit les messages du formulaire de contact
MAIL_TO=
# Expéditeur affiché (souvent identique à SMTP_USER)
MAIL_FROM=
